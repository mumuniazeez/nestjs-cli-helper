{
  "name": "@azcodes/nestjs-cli-helper",
  "version": "1.1.2",
  "description": "A Nestjs Cli helper that help you install Nestjs modules",
  "keywords": [
    "Nestjs",
    "CLI"
  ],
  "homepage": "https://nestjs-cli-helper.vercel.app",
  "bugs": {
    "url": "https://github.com/mumuniazeez/nestjs-cli-helper/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mumuniazeez/nestjs-cli-helper.git"
  },
  "license": "MIT",
  "author": "AzCodes",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "nestjs-helper": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "publish:npm": "pnpm build; npm publish --access=public",
    "docs:build": "pnpm --filter docs build",
    "docs:start": "pnpm --filter docs start"
  },
  "devDependencies": {
    "@types/node": "^25.9.5",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "inquirer": "^14.0.2",
    "is-installed-globally": "^1.0.0",
    "ora": "^9.4.0",
    "resolve-global": "^2.0.0"
  },
  "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25"
}
